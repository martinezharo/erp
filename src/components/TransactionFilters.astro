---
interface Props {
    channels?: string[];
}

const { channels = [] } = Astro.props;
const { t } = Astro.locals;

const inputClass =
    "w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-primary-500 transition-all";
---

<div
    class="mb-6 flex flex-col lg:flex-row lg:items-center gap-3 lg:gap-4"
>
    <!-- View mode toggle (moved from the page header) -->
    <div
        class="flex items-center bg-white/5 border border-white/10 rounded-xl p-1 gap-1 shrink-0 w-fit"
    >
        <button
            id="btn-view-daily"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all bg-white/10 text-white"
            title={t("transactions.viewDaily")}
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
            </svg>
            <span class="hidden sm:inline">{t("transactions.daily")}</span>
        </button>
        <button
            id="btn-view-list"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all text-slate-400 hover:text-white"
            title={t("transactions.viewList")}
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h6a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
            </svg>
            <span class="hidden sm:inline">{t("transactions.list")}</span>
        </button>
    </div>

    <!-- Filters (only visible in list mode; toggled by TransactionsList script) -->
    <div
        id="txn-filters"
        class="hidden flex-1 flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 min-w-0"
    >
        <!-- Search -->
        <div class="relative flex-1 min-w-0">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none"
                viewBox="0 0 20 20"
                fill="currentColor"
            >
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
            <input
                id="filter-search"
                type="text"
                class={inputClass + " pl-9"}
                placeholder={t("filters.search")}
            />
        </div>

        <!-- Type -->
        <select id="filter-type" class={inputClass + " sm:w-40 shrink-0"}>
            <option value="">{t("filters.allTypes")}</option>
            <option value="venta">{t("filters.typeVenta")}</option>
            <option value="compra">{t("filters.typeCompra")}</option>
            <option value="ingreso">{t("filters.typeIngreso")}</option>
            <option value="gasto">{t("filters.typeGasto")}</option>
        </select>

        <!-- Channel -->
        <select id="filter-channel" class={inputClass + " sm:w-40 shrink-0"}>
            <option value="">{t("filters.allChannels")}</option>
            {channels.map((c) => <option value={c}>{c}</option>)}
        </select>

        <!-- More filters (date + amount) -->
        <div class="relative shrink-0">
            <button
                id="filters-more-btn"
                type="button"
                class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 text-sm font-medium text-slate-200 transition-colors w-full sm:w-auto justify-center"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" />
                </svg>
                {t("filters.more")}
                <span
                    id="filters-badge"
                    class="hidden items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-primary-500 text-white text-[10px] font-bold"
                >0</span>
            </button>

            <div
                id="filters-more-panel"
                class="hidden absolute right-0 top-full mt-2 w-72 p-4 rounded-xl bg-[#0f1016] border border-white/10 shadow-xl backdrop-blur-xl z-50 space-y-4"
            >
                <div>
                    <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
                        {t("filters.dateRange")}
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[10px] text-slate-500 mb-1">{t("filters.dateFrom")}</label>
                            <input id="filter-date-from" type="date" class={inputClass} />
                        </div>
                        <div>
                            <label class="block text-[10px] text-slate-500 mb-1">{t("filters.dateTo")}</label>
                            <input id="filter-date-to" type="date" class={inputClass} />
                        </div>
                    </div>
                </div>
                <div>
                    <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
                        {t("filters.amountRange")}
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[10px] text-slate-500 mb-1">{t("filters.amountMin")}</label>
                            <input id="filter-amount-min" type="number" step="0.01" class={inputClass} placeholder="0.00" />
                        </div>
                        <div>
                            <label class="block text-[10px] text-slate-500 mb-1">{t("filters.amountMax")}</label>
                            <input id="filter-amount-max" type="number" step="0.01" class={inputClass} placeholder="0.00" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Clear -->
        <button
            id="filter-clear"
            type="button"
            class="hidden sm:flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 transition-colors shrink-0"
            title={t("filters.clear")}
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            <span class="hidden lg:inline">{t("filters.clear")}</span>
        </button>
    </div>
</div>
